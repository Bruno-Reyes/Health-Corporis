<div class="Pcontenido quitar">
    <div class="container p-4">
        <div class="row">
            <div class=" col-lg-12 mb-2">                
            <div class="btn-group-vertical" role="group" aria-label="Button group with nested dropdown">
                <a href="/profile"><i class="fas fa-backward"></i> Regresar</a>
            </div>
            </div>
            <div class="col col-lg-4 col-md-6 col-sm-8 col-xs-12 mb-4">
                <div class="card border-success">
                    <div class="card-header">
                        <h4 class="card-title">Usuario</h4>
                    </div>
                    <div class="card-body">
                        <form action="/user/username/{{user.id_usu}}" method="post" autocomplete="off"
                            onsubmit="return validarUsuario();">
                            <div class="form-group">
                                <input type="text" class="form-control card-text" name="Username"
                                    value="{{user.nom_usu}}" maxlength="20" id="txtnombre">
                            </div>
                            <div class="form-group text-center">
                                <button class="btn btn-outline-info"><i class="far fa-save"></i></button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

