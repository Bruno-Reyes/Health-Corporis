<link rel="stylesheet" href="/css/listusers.css">
<div class="container p-4">
    <div class="row">
        <div class="mx-auto">
            <table class="table">
                <thead class="thead-light">
                    <tr>
                        <th scope="col">Usuario</th>
                        <th scope="col">Primer Nombre</th>
                        <th scope="col">Segundo Nombre</th>
                        <th scope="col">Apellido Paterno</th>
                        <th scope="col">Apellido Materno</th>
                        <th scope="col">Edad</th>
                        <th scope="col">Ultimo Registro</th>
                        <th scope="col">#</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each listusers}}
                    <tr>
                        <th> {{nom_usu}} </th>
                        <td> {{pri_nom}} </td>
                        <td> {{sec_nom}} </td>
                        <td> {{ape_pat}} </td>
                        <td> {{ape_mat}} </td>
                        <td> {{eda_usu}} </td>
                        <td> {{fdr_his}} </td>
                        <td> <a href="/admin/users/delete/{{id_usu}}"><i class="fas fa-eraser"></i></a> </td>
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="8"> Aun no exiten usuarios registrados.  Ve a repartir flyers </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>

            <div>
                <a href="/profile"><i class="fas fa-backward"></i> Regresar</a>
            </div>
        </div>
    </div>
</div>