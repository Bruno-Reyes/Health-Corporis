<div class="container p-4">
    <script src="/js/tipsval.js"></script> 
    <div class="row">
        <div class="col-md-4 mx-auto">
            <div class="card" style="color: #212121;">
                <div class="card-body">
                    <form action="/admin/tips/add" method="post" autocomplete="off">
                        <div class="form-group">
                            <input type="text" class="form-control" name="Titulo" id="Titulo" placeholder="Titulo" autofocus maxlength="20" required="return true">
                        </div>
                        <div class="form-group">
                            <textarea name="Descripcion" id="Descripcion" rows="3" class="form-control" placeholder="¿En que consiste el tip?" maxlength="250" required="return true"></textarea>
                        </div>
                        <div class="form-group">
                            <button class="btn btn-outline-info btn-block" onclick="return Tip()"><i class="far fa-save"></i></button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>